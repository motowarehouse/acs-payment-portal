# ─── Database ────────────────────────────────────────────────────────────────
# Railway PostgreSQL connection string (copy from the Railway dashboard)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Full URL of the deployed app (Railway provides this). Locally: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# ─── Seed accounts (only used the first time you run `npm run db:seed`) ───────
# Two logins, e.g. you and the shop owner. Change these before seeding.
ADMIN1_USERNAME="nikolas"
ADMIN1_PASSWORD="change-me-1"
ADMIN1_NAME="Nikolas"

ADMIN2_USERNAME="owner"
ADMIN2_PASSWORD="change-me-2"
ADMIN2_NAME="Owner"
